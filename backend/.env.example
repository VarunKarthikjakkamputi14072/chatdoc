# --- Provider selection ---
# LLM_PROVIDER:   openai (default) | groq | transit
# EMBED_PROVIDER: openai (default) | local (fastembed, no key) | transit
LLM_PROVIDER=openai
EMBED_PROVIDER=openai

# OpenAI (used when *_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# Transit — self-hosted AI gateway (used when *_PROVIDER=transit).
# Routes chat + embeddings through one metered, cached af_ key (NVIDIA NIM
# behind it), so repeated questions and re-embeds are served from Redis for $0.
TRANSIT_BASE_URL=https://apiforge-jnwp.onrender.com/api/v1
TRANSIT_API_KEY=af_...
TRANSIT_MODEL=meta/llama-3.3-70b-instruct
TRANSIT_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
TRANSIT_EMBED_DIM=1024

# Groq (used when LLM_PROVIDER=groq) — LLM only, no embeddings
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local embeddings (used when EMBED_PROVIDER=local) — runs offline
LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5

QDRANT_HOST=localhost
QDRANT_PORT=6333
