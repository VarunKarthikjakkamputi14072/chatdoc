# --- Provider selection ---
# LLM_PROVIDER: openai (default) | groq
# EMBED_PROVIDER: openai (default) | local  (local = fastembed, no API key)
LLM_PROVIDER=openai
EMBED_PROVIDER=openai

# OpenAI (used when *_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# Groq (used when LLM_PROVIDER=groq) — LLM only, no embeddings
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local embeddings (used when EMBED_PROVIDER=local) — runs offline
LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5

QDRANT_HOST=localhost
QDRANT_PORT=6333
